# ===========================
# ドメイン設定
# ===========================
DOMAIN=yourdomain.com  # あなたのドメインに変更してください

# ===========================
# データベース設定
# ===========================
POSTGRES_PASSWORD=your-secure-password-here  # 必ず変更してください！
LOBE_DB_NAME=lobechat

# ===========================
# セキュリティキー（必ず変更してください）
# ===========================
# 以下のコマンドで生成できます:
# openssl rand -base64 24
KEY_VAULTS_SECRET=your-32-char-secret-key-here

# openssl rand -base64 32
NEXT_AUTH_SECRET=your-next-auth-secret-here

# ===========================
# Casdoor認証設定
# ===========================
# 初回起動後、Casdoorの管理画面で作成したアプリのIDとSecretを設定
AUTH_CASDOOR_ID=your-casdoor-app-id
AUTH_CASDOOR_SECRET=your-casdoor-app-secret

# ===========================
# Backblaze B2設定
# ===========================
# エンドポイントはリージョンによって異なります
# US West: s3.us-west-001.backblazeb2.com
# US East: s3.us-east-001.backblazeb2.com  
# EU Central: s3.eu-central-001.backblazeb2.com
S3_ENDPOINT=https://s3.us-west-001.backblazeb2.com
S3_PUBLIC_DOMAIN=https://f001.backblazeb2.com/file/your-bucket-name
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-backblaze-keyID
S3_SECRET_ACCESS_KEY=your-backblaze-applicationKey

# ===========================
# LLMプロバイダー設定
# ===========================

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_MODEL_LIST=anthropic/claude-3.5-sonnet,openai/gpt-4o,google/gemini-pro-1.5

# Runpod (OpenAI互換API)
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_API_URL=https://your-runpod-endpoint/v1
RUNPOD_MODEL_LIST=llama-3-70b,mixtral-8x7b

# その他のプロバイダー（オプション）
# ANTHROPIC_API_KEY=sk-ant-xxxx
# GOOGLE_API_KEY=xxxx

# ===========================
# プロキシ設定（必要な場合）
# ===========================
# PROXY_URL=http://your-proxy:port