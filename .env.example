# ===========================
# 基本設定
# ===========================
APP_URL=http://localhost:3210
LOBE_PORT=3210

# ===========================
# データベース設定
# ===========================
POSTGRES_PASSWORD=your-secure-password-here
LOBE_DB_NAME=lobechat

# ===========================
# セキュリティキー（必ず変更してください）
# ===========================
KEY_VAULTS_SECRET=your-32-char-secret-key-here
NEXT_AUTH_SECRET=your-next-auth-secret-here

# ===========================
# 認証設定 (Casdoor)
# ===========================
AUTH_CASDOOR_ISSUER=http://localhost:8000
AUTH_CASDOOR_ID=your-casdoor-app-id
AUTH_CASDOOR_SECRET=your-casdoor-app-secret

# ===========================
# S3互換ストレージ設定
# ===========================

# MinIOを使用する場合
# S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_DOMAIN=http://localhost:9000
# S3_BUCKET=lobe
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_ENABLE_PATH_STYLE=1

# AWS S3を使用する場合
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_PUBLIC_DOMAIN=https://your-bucket.s3.amazonaws.com
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=your-aws-access-key
# S3_SECRET_ACCESS_KEY=your-aws-secret-key
# S3_ENABLE_PATH_STYLE=0

# Cloudflare R2を使用する場合
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_PUBLIC_DOMAIN=https://your-public-domain.com
# S3_BUCKET=your-r2-bucket
# S3_ACCESS_KEY_ID=your-r2-access-key
# S3_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_ENABLE_PATH_STYLE=0

# ===========================
# AIプロバイダー設定（オプション）
# ===========================

# OpenAI
# OPENAI_API_KEY=sk-xxxx
# OPENAI_PROXY_URL=https://api.openai.com/v1
# OPENAI_MODEL_LIST=gpt-4o,gpt-4o-mini,gpt-3.5-turbo

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_MODEL_LIST=claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022

# Google AI
# GOOGLE_API_KEY=xxxx
# GOOGLE_MODEL_LIST=gemini-2.0-flash-exp,gemini-1.5-pro,gemini-1.5-flash

# その他のプロバイダーは Dockerfile.database を参照してください

# ===========================
# プロキシ設定（必要な場合）
# ===========================
# HTTP_PROXY=http://localhost:7890
# HTTPS_PROXY=http://localhost:7890
# PROXY_URL=http://localhost:7890